// Load saved values
function loadSaved() {
  try {
    const saved = JSON.parse(localStorage.getItem('stats_build') || '{}');
    Object.values(DATA).forEach(cat => {
      cat.rows.forEach(row => {
        if (saved[row.id] !== undefined) row.yours = saved[row.id];
      });
    });
  } catch(e) {}
}

function saveAll() {
  const out = {};
  Object.values(DATA).forEach(cat => {
    cat.rows.forEach(row => {
      const el = document.getElementById(row.id);
      if (el) out[row.id] = parseFloat(el.value) || 0;
    });
  });
  localStorage.setItem('stats_build', JSON.stringify(out));
  const msg = document.getElementById('saveMsg');
  msg.classList.add('visible');
  setTimeout(() => msg.classList.remove('visible'), 2000);
  updateAll();
}

function resetAll() {
  if (!confirm('Réinitialiser toutes les valeurs ?')) return;
  localStorage.removeItem('stats_build');
  Object.values(DATA).forEach(cat => {
    cat.rows.forEach(row => {
      const el = document.getElementById(row.id);
      if (el) el.value = row.yours;
    });
  });
  updateAll();
}

function getCardTotal(catKey) {
  const cat = DATA[catKey];
  return cat.rows.reduce((sum, row) => {
    const el = document.getElementById(row.id);
    return sum + (parseFloat(el?.value) || 0);
  }, 0);
}

function updateCard(catKey) {
  const cat = DATA[catKey];
  const yours = getCardTotal(catKey);
  const missing = cat.best_total - yours;
  const pct = Math.min(100, (yours / cat.best_total) * 100);

  const totalEl = document.getElementById(`${catKey}_total`);
  const missEl  = document.getElementById(`${catKey}_missing`);
  const fillEl  = document.getElementById(`${catKey}_fill`);
  const yoursEl = document.getElementById(`${catKey}_yours`);

  if (totalEl) totalEl.textContent = `${yours.toFixed(1)}% / ${cat.best_total}%`;
  if (yoursEl) yoursEl.textContent = `${yours.toFixed(1)}%`;
  if (missEl)  missEl.textContent  = `${Math.max(0, missing).toFixed(1)}%`;
  if (fillEl)  fillEl.style.width  = `${pct}%`;
}

function updateAll() {
  Object.keys(DATA).forEach(updateCard);
}

function diffBadge(yours, best) {
  const diff = best - yours;
  if (diff <= 0) return '';
  const cls = diff <= 2 ? 'diff-warn' : 'diff-bad';
  return `<span class="diff-badge ${cls}">−${diff.toFixed(1)}%</span>`;
}

function buildCard(catKey) {
  const cat = DATA[catKey];
  const yours_total = cat.rows.reduce((s, r) => s + r.yours, 0);
  const missing = cat.best_total - yours_total;
  const pct = Math.min(100, (yours_total / cat.best_total) * 100);

  let rows = cat.rows.map(row => `
    <div class="row">
      <span class="row-label">${row.label}</span>
      <span class="row-best">${row.best}%</span>
      <div class="input-wrap">
        <input class="stat-input" type="number" id="${row.id}"
          value="${row.yours}" min="0" max="999" step="0.1"
          oninput="updateCard('${catKey}')">
        <span class="pct-symbol">%</span>
      </div>
    </div>
  `).join('');

  return `
    <div class="card ${cat.class}">
      <div class="card-header">
        <div class="card-dot"></div>
        <span class="card-title">${cat.label}</span>
        <span class="card-total" id="${catKey}_total">${yours_total.toFixed(1)}% / ${cat.best_total}%</span>
      </div>
      <div class="progress-bar">
        <div class="progress-fill" id="${catKey}_fill" style="width:${pct}%"></div>
      </div>
      <div class="card-body">
        <div class="row" style="padding-top:10px;padding-bottom:2px">
          <span style="font-size:0.7rem;letter-spacing:0.06em;color:var(--muted);font-weight:700;text-transform:uppercase;">Catégorie</span>
          <span style="font-size:0.7rem;letter-spacing:0.06em;color:var(--muted);font-weight:700;text-transform:uppercase;">Meilleur</span>
          <span style="font-size:0.7rem;letter-spacing:0.06em;color:var(--muted);font-weight:700;text-transform:uppercase;width:90px;text-align:right;">Tes stats</span>
        </div>
        ${rows}
        <div class="divider"></div>
        <div class="summary-row yours">
          <span class="summary-label">Ton build</span>
          <span class="summary-val" id="${catKey}_yours">${yours_total.toFixed(1)}%</span>
        </div>
        <div class="summary-row missing">
          <span class="summary-label">Manquant</span>
          <span class="summary-val" id="${catKey}_missing">${Math.max(0, missing).toFixed(1)}%</span>
        </div>
      </div>
    </div>
  `;
}

loadSaved();
const grid = document.getElementById('grid');
grid.innerHTML = Object.keys(DATA).map(buildCard).join('');
</script>
</body>
